{% extends "layouts.master" %}

{% block content %}
<section class="py-12 md:py-24 bg-gray-50">
    <div class="container mx-auto px-4">
        <h1 class="text-4xl font-extrabold text-gray-900 mb-12 flex items-center gap-4">
            <svg class="w-10 h-10 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
            سلة التسوق الخاصة بك
        </h1>

        <div class="flex flex-col lg:flex-row gap-12 items-start">
            {# Cart Items #}
            <div class="w-full lg:w-2/3 space-y-6">
                {% if cart.items|length > 0 %}
                    <div class="bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
                        <table class="w-full text-right border-collapse">
                            <thead class="bg-gray-50 border-b border-gray-100 hidden md:table-header-group">
                                <tr>
                                    <th class="px-8 py-4 text-xs font-bold text-gray-500 uppercase tracking-widest">المنتج</th>
                                    <th class="px-8 py-4 text-xs font-bold text-gray-500 uppercase tracking-widest">السعر</th>
                                    <th class="px-8 py-4 text-xs font-bold text-gray-500 uppercase tracking-widest">الكمية</th>
                                    <th class="px-8 py-4 text-xs font-bold text-gray-500 uppercase tracking-widest">المجموع</th>
                                    <th class="px-8 py-4"></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                {% for item in cart.items %}
                                <tr class="group hover:bg-gray-50/50 transition-colors">
                                    <td class="px-8 py-8">
                                        <div class="flex items-center gap-6">
                                            <div class="h-20 w-20 bg-gray-100 rounded-2xl overflow-hidden border border-gray-100 group-hover:scale-105 transition-transform">
                                                <img src="{{ item.product.image.url }}" alt="{{ item.product.name }}" class="w-full h-full object-cover">
                                            </div>
                                            <div>
                                                <h3 class="font-bold text-gray-900 text-lg hover:text-indigo-600 transition-colors">
                                                    <a href="{{ item.product.url }}">{{ item.product.name }}</a>
                                                </h3>
                                                <p class="text-sm text-gray-500 mt-1">{{ item.label }}</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-8 py-8 font-bold text-gray-900">{{ item.price|money }}</td>
                                    <td class="px-8 py-8">
                                        <div class="flex items-center gap-2 bg-gray-100 border border-gray-200 p-1.5 rounded-xl w-fit">
                                            <button type="button" class="h-8 w-8 flex items-center justify-center rounded-lg hover:bg-white hover:shadow-sm transition-all">&minus;</button>
                                            <input type="number" value="{{ item.quantity }}" class="w-10 text-center font-bold bg-transparent border-none focus:ring-0 text-sm">
                                            <button type="button" class="h-8 w-8 flex items-center justify-center rounded-lg hover:bg-white hover:shadow-sm transition-all">&plus;</button>
                                        </div>
                                    </td>
                                    <td class="px-8 py-8 font-extrabold text-indigo-600">{{ (item.price * item.quantity)|money }}</td>
                                    <td class="px-8 py-8">
                                        <button class="p-2 text-gray-400 hover:text-rose-500 hover:bg-rose-50 rounded-xl transition-all">
                                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="bg-white rounded-3xl p-16 text-center border border-gray-100 shadow-sm">
                        <div class="h-24 w-24 bg-indigo-50 text-indigo-600 flex items-center justify-center rounded-full mx-auto mb-8">
                            <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                        </div>
                        <h2 class="text-2xl font-bold text-gray-900 mb-4">السلة فارغة حالياً</h2>
                        <p class="text-gray-500 mb-10 max-w-sm mx-auto leading-relaxed">يبدو أنك لم تقم بإضافة أي منتجات للسلة بعد. تصفح منتجاتنا المميزة وابدأ التسوق الآن.</p>
                        <a href="{{ url('products') }}" class="bg-indigo-600 text-white font-bold py-4 px-10 rounded-2xl shadow-lg shadow-indigo-200 hover:bg-indigo-700 transition-all inline-block">تصفح المنتجات</a>
                    </div>
                {% endif %}

                {# Extra services/promos #}
                <div class="p-8 border border-dashed border-gray-300 rounded-3xl flex items-center justify-between text-gray-600 bg-white/50">
                    <div class="flex items-center gap-4">
                        <div class="h-12 w-12 bg-white flex items-center justify-center rounded-xl shadow-sm border border-gray-100 font-bold text-indigo-600 text-xl">%</div>
                        <div>
                            <h4 class="font-bold text-gray-900">هل لديك كود خصم؟</h4>
                            <p class="text-xs">سيتم تطبيق الخصم في الخطوة القادمة</p>
                        </div>
                    </div>
                    <form class="flex items-center gap-2 h-fit">
                        <input type="text" placeholder="أدخل الكود هنا" class="bg-white border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:ring-indigo-500 focus:border-indigo-500 w-32 sm:w-auto">
                        <button class="bg-gray-900 text-white text-xs font-bold py-3 px-6 rounded-xl hover:bg-indigo-600 transition-all">تفعيل</button>
                    </form>
                </div>
            </div>

            {# Order Summary Sidebar #}
            <div class="w-full lg:w-1/3 space-y-6">
                <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-xl space-y-8 sticky top-28">
                    <h2 class="text-xl font-bold text-gray-900">ملخص الطلب</h2>
                    
                    <div class="space-y-4 pt-4 border-t border-gray-100">
                        <div class="flex justify-between items-center text-gray-600">
                            <span>المجموع لعدد ({{ cart.count }}) منتجات</span>
                            <span>{{ cart.subtotal|money }}</span>
                        </div>
                        <div class="flex justify-between items-center text-gray-600">
                            <span>الشحن</span>
                            <span class="text-emerald-600 font-medium">حسب العنوان</span>
                        </div>
                        <div class="flex justify-between items-center text-gray-600">
                            <span>الضريبة (15%)</span>
                            <span>{{ cart.tax|money }}</span>
                        </div>
                    </div>

                    <div class="pt-6 border-t border-gray-100 flex justify-between items-end">
                        <div>
                            <span class="text-sm text-gray-500 block mb-1">المجموع النهائي</span>
                            <span class="text-3xl font-black text-indigo-600 leading-none">{{ cart.total|money }}</span>
                        </div>
                        <div class="text-xs text-gray-400 text-left">شامل الضريبة</div>
                    </div>

                    <a href="{{ url('checkout') }}" class="w-full bg-indigo-600 text-white font-black py-4 px-10 rounded-2xl shadow-lg shadow-indigo-100 hover:bg-indigo-700 hover:-translate-y-0.5 transition-all flex items-center justify-center gap-3">
                        إتمام الطلب
                        <svg class="w-5 h-5 translate-y-[1px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </a>

                    <div class="flex items-center justify-center gap-4 grayscale opacity-30 pt-4">
                        <img src="https://img.icons8.com/color/48/000000/visa.png" class="h-6" alt="Visa">
                        <img src="https://img.icons8.com/color/48/000000/mastercard.png" class="h-6" alt="MasterCard">
                        <img src="https://img.icons8.com/color/48/000000/apple-pay.png" class="h-6" alt="Apple Pay">
                        <img src="https://img.icons8.com/color/48/000000/mada.png" class="h-6" alt="Mada">
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
