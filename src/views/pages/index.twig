{% extends "layouts.master" %}

{% block content %}
    {# Hero Section #}
    <section class="hero-gradient relative py-24 md:py-32 overflow-hidden">
        <div class="absolute inset-0 bg-grid-white/[0.05] bg-[size:40px_40px]"></div>
        <div class="container mx-auto px-4 relative z-10 flex flex-col items-center text-center">
            <span class="bg-indigo-500/20 text-indigo-200 border border-indigo-400/30 px-4 py-1.5 rounded-full text-sm font-medium mb-6 backdrop-blur-sm animate-fade-in">
                أحدث التشكيلات وصلت الآن!
            </span>
            <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-6 leading-tight max-w-3xl">
                تجربة تسوق فريدة تجمع بين <span class="text-indigo-300">الأناقة والجودة</span>
            </h1>
            <p class="text-lg md:text-xl text-indigo-100/80 mb-10 max-w-2xl leading-relaxed">
                اكتشف مجموعة واسعة من المنتجات المختارة بعناية لتناسب ذوقك الرفيع. توصيل سريع وضمان جودة.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
                <a href="{{ url('products') }}" class="bg-white text-indigo-900 px-8 py-4 rounded-xl font-bold hover:bg-indigo-50 transition-all flex items-center justify-center gap-2">
                    تسوق الآن
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                </a>
                <a href="#categories" class="bg-indigo-800/30 text-white border border-indigo-400/20 px-8 py-4 rounded-xl font-bold hover:bg-indigo-800/50 transition-all backdrop-blur-sm">
                    تصفح التصنيفات
                </a>
            </div>
        </div>
    </section>

    {# Features #}
    <section class="py-16 bg-white border-b border-gray-100">
        <div class="container mx-auto px-4">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="flex items-center gap-4 p-6 rounded-2xl hover:bg-gray-50 transition-colors group">
                    <div class="h-12 w-12 bg-indigo-50 text-indigo-600 flex items-center justify-center rounded-xl group-hover:bg-indigo-600 group-hover:text-white transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-gray-900">جودة مضمونة</h3>
                        <p class="text-sm text-gray-500">نختار منتجاتنا بدقة عالية لضمان رضاكم.</p>
                    </div>
                </div>
                <div class="flex items-center gap-4 p-6 rounded-2xl hover:bg-gray-50 transition-colors group">
                    <div class="h-12 w-12 bg-indigo-50 text-indigo-600 flex items-center justify-center rounded-xl group-hover:bg-indigo-600 group-hover:text-white transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-gray-900">توصيل سريع</h3>
                        <p class="text-sm text-gray-500">نصل إليك أينما كنت في أسرع وقت ممكن.</p>
                    </div>
                </div>
                <div class="flex items-center gap-4 p-6 rounded-2xl hover:bg-gray-50 transition-colors group">
                    <div class="h-12 w-12 bg-indigo-50 text-indigo-600 flex items-center justify-center rounded-xl group-hover:bg-indigo-600 group-hover:text-white transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                    </div>
                    <div>
                        <h3 class="font-bold text-gray-900">دفع آمن</h3>
                        <p class="text-sm text-gray-500">خيارات دفع متعددة وآمنة تماماً.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# Featured Products #}
    <section class="py-24">
        <div class="container mx-auto px-4">
            <div class="flex justify-between items-end mb-12">
                <div>
                    <h2 class="text-3xl font-extrabold text-gray-900 mb-2">منتجاتنا المختارة</h2>
                    <p class="text-gray-500">مجموعة من أفضل ما نقدمه لعملائنا الكرام</p>
                </div>
                <a href="{{ url('products') }}" class="text-indigo-600 font-bold hover:underline">عرض الكل &larr;</a>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                {# Product Template Placeholder (Looping starts here) #}
                {% for product in products %}
                <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all group">
                    <div class="relative aspect-square bg-gray-100 overflow-hidden">
                        <img src="{{ product.image.url }}" alt="{{ product.name }}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                        {% if product.on_sale %}
                        <span class="absolute top-4 left-4 bg-rose-500 text-white text-[10px] sm:text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">خصم</span>
                        {% endif %}
                        <button class="absolute bottom-4 right-4 h-10 w-10 bg-white shadow-lg flex items-center justify-center rounded-full opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all hover:bg-indigo-600 hover:text-white">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
                        </button>
                    </div>
                    <div class="p-4 sm:p-6">
                        <h3 class="font-bold text-gray-900 mb-2 line-clamp-1 hover:text-indigo-600 transition-colors">
                            <a href="{{ product.url }}">{{ product.name }}</a>
                        </h3>
                        <div class="flex items-center gap-2">
                            <span class="text-indigo-600 font-bold text-lg">{{ product.price|money }}</span>
                            {% if product.on_sale %}
                            <span class="text-gray-400 text-sm line-through">{{ product.regular_price|money }}</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% else %}
                    {# Mock display if no products found #}
                    {% for i in 1..4 %}
                    <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden animate-pulse">
                        <div class="aspect-square bg-gray-200"></div>
                        <div class="p-6">
                            <div class="h-4 bg-gray-200 rounded w-3/4 mb-4"></div>
                            <div class="h-6 bg-gray-200 rounded w-1/2"></div>
                        </div>
                    </div>
                    {% endfor %}
                {% endfor %}
            </div>
        </div>
    </section>

{% endblock %}
