{% extends "layouts.master" %}

{% block content %}
<section class="py-12 md:py-24">
    <div class="container mx-auto px-4">
        <div class="flex flex-col lg:flex-row gap-16">
            {# Product Images #}
            <div class="w-full lg:w-1/2 space-y-4">
                <div class="aspect-square bg-white rounded-3xl border border-gray-100 overflow-hidden shadow-sm group">
                    <img src="{{ product.image.url }}" alt="{{ product.name }}" class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-500">
                </div>
                <div class="grid grid-cols-4 gap-4">
                    {% for image in product.images %}
                    <div class="aspect-square bg-white rounded-xl border border-gray-100 overflow-hidden cursor-pointer hover:border-indigo-600 transition-all p-2">
                        <img src="{{ image.url }}" alt="{{ product.name }}" class="w-full h-full object-contain">
                    </div>
                    {% endfor %}
                </div>
            </div>

            {# Product Info #}
            <div class="w-full lg:w-1/2 space-y-10">
                <div class="space-y-4">
                    <div class="flex items-center gap-4">
                        {% if product.category %}
                        <a href="{{ product.category.url }}" class="text-xs font-bold text-indigo-600 bg-indigo-50 px-3 py-1 rounded-full uppercase tracking-widest">{{ product.category.name }}</a>
                        {% endif %}
                        {% if product.is_available %}
                        <span class="text-xs font-medium text-emerald-600 flex items-center gap-1.5">
                            <span class="h-1.5 w-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
                            متوفر في المخزون
                        </span>
                        {% endif %}
                    </div>
                    <h1 class="text-4xl font-extrabold text-gray-900 leading-tight">{{ product.name }}</h1>
                    <div class="flex items-center gap-6">
                        <span class="text-3xl font-black text-indigo-600">{{ product.price|money }}</span>
                        {% if product.on_sale %}
                        <span class="text-xl text-gray-400 line-through">{{ product.regular_price|money }}</span>
                        <span class="bg-rose-100 text-rose-600 text-sm font-bold px-3 py-1 rounded-lg">وفر {{ (product.regular_price - product.price)|money }}</span>
                        {% endif %}
                    </div>
                </div>

                <div class="prose prose-slate prose-indigo max-w-none text-gray-600 leading-relaxed">
                    {{ product.description|raw }}
                </div>

                {# Add to Cart Form #}
                <form action="{{ url('cart/add') }}" method="POST" class="space-y-8 bg-gray-50 p-8 rounded-3xl border border-gray-100 shadow-inner">
                    <input type="hidden" name="id" value="{{ product.id }}">
                    
                    {# Options/Variants would be dynamically rendered here #}
                    {% if product.options %}
                    <div class="space-y-6">
                        {% for option in product.options %}
                        <div class="space-y-3">
                            <label class="block font-bold text-gray-900">{{ option.name }}</label>
                            <div class="flex flex-wrap gap-3">
                                {% for value in option.values %}
                                <label class="relative cursor-pointer group">
                                    <input type="radio" name="{{ option.id }}" value="{{ value.id }}" class="sr-only peer">
                                    <div class="px-6 py-3 bg-white border border-gray-200 rounded-xl text-sm font-medium peer-checked:border-indigo-600 peer-checked:bg-indigo-50 peer-checked:text-indigo-900 transition-all hover:bg-gray-100">
                                        {{ value.name }}
                                    </div>
                                </label>
                                {% endfor %}
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    {% endif %}

                    <div class="flex flex-col sm:flex-row gap-4 items-center pt-2">
                        <div class="flex items-center gap-2 bg-white border border-gray-200 p-2 rounded-2xl w-full sm:w-auto">
                            <button type="button" class="h-10 w-10 flex items-center justify-center rounded-xl hover:bg-gray-100 transition-colors">&minus;</button>
                            <input type="number" name="quantity" value="1" min="1" class="w-12 text-center font-bold bg-transparent border-none focus:ring-0">
                            <button type="button" class="h-10 w-10 flex items-center justify-center rounded-xl hover:bg-gray-100 transition-colors">&plus;</button>
                        </div>
                        <button type="submit" class="flex-1 w-full bg-indigo-600 text-white font-black py-4 px-10 rounded-2xl shadow-lg shadow-indigo-200 hover:bg-indigo-700 hover:-translate-y-0.5 transition-all">أضف للسلة الآن</button>
                    </div>
                </form>

                {# Features Grid #}
                <div class="grid grid-cols-2 gap-6 pt-10 border-t border-gray-100">
                    <div class="flex items-start gap-4">
                        <div class="p-3 bg-white shadow-sm border border-gray-100 rounded-xl">
                            <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4M12 20V4"></path></svg>
                        </div>
                        <div>
                            <h5 class="text-sm font-bold text-gray-900 mb-1">دفع إلكتروني آمن</h5>
                            <p class="text-xs text-gray-500">مشفر وآمن 100%</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="p-3 bg-white shadow-sm border border-gray-100 rounded-xl">
                            <svg class="w-5 h-5 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </div>
                        <div>
                            <h5 class="text-sm font-bold text-gray-900 mb-1">سياسة استبدال مرنة</h5>
                            <p class="text-xs text-gray-500">خلال 14 يوم عمل</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
